# Copy this file to .env only if your shell or launcher loads dotenv files.
# The bundled scripts read process environment variables; never commit real values.

# Optional: ElevenLabs text-to-speech
ELEVENLABS_API_KEY=

# Reserved for a custom iFlytek/XFYun adapter. The current public scripts do not
# send these values anywhere until you implement or enable such an adapter.
XFYUN_APP_ID=
XFYUN_API_KEY=
XFYUN_API_SECRET=
